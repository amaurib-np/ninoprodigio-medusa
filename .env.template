# ninoprodigio-medusa environment template.
# Copy to .env and fill in. NEVER commit .env. See docs/integration-contract.md
# "Shared / required environment" for the authoritative list.

# --- Core ---
NODE_ENV=development
# Medusa Postgres. Matches docker-compose.yml for local dev.
DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa
# Cache, event bus, and workflow engine. Omit locally to use in-memory fallbacks.
REDIS_URL=redis://localhost:6379

# Worker mode: "shared" (single instance, local/dev), "server", or "worker".
MEDUSA_WORKER_MODE=shared

# --- Auth / CORS ---
STORE_CORS=http://localhost:8000,http://localhost:3000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,http://localhost:3000
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# --- Stripe (TWO accounts; payments only) ---
# Mundo Espiritual: physical + digital products. Provider id pp_stripe_mundo.
# Stripe webhook endpoint: {server_url}/hooks/payment/stripe_mundo
STRIPE_MUNDO_SECRET_KEY=
STRIPE_MUNDO_WEBHOOK_SECRET=
# Gedelimbo: minutes packages only (later phase; leave empty to skip registration).
# Stripe webhook endpoint: {server_url}/hooks/payment/stripe_gedelimbo
STRIPE_GEDELIMBO_SECRET_KEY=
STRIPE_GEDELIMBO_WEBHOOK_SECRET=

# --- GoShippo (fulfillment: rates + labels) ---
# Leave SHIPPO_API_KEY empty to skip the provider (manual fulfillment only).
SHIPPO_API_KEY=
SHIPPO_FROM_NAME=
SHIPPO_FROM_COMPANY=
SHIPPO_FROM_STREET1=
SHIPPO_FROM_CITY=
SHIPPO_FROM_STATE=
SHIPPO_FROM_ZIP=
SHIPPO_FROM_COUNTRY=US
SHIPPO_FROM_PHONE=

# --- Resend (notifications: order emails) ---
# Leave RESEND_API_KEY empty to skip the provider. Use onboarding@resend.dev as
# RESEND_FROM_EMAIL if you don't have a verified domain yet.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Web platform notification (Medusa -> Next.js app; order.placed) ---
WEB_PLATFORM_WEBHOOK_URL=
WEB_PLATFORM_WEBHOOK_SECRET=
# Shared secret for platform -> Medusa server-only calls (e.g. POST
# /store/link-customer). Must match MEDUSA_PLATFORM_SECRET on the platform.
# Checked via the x-platform-secret header; required in addition to the
# publishable API key (which is public).
PLATFORM_SHARED_SECRET=

# --- Sanity (product.* subscriber: auto-create productDescription stubs) ---
# Write token must have create/patch access to the platform's Sanity dataset.
# Leave SANITY_WRITE_TOKEN empty to skip the stub subscriber.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_WRITE_TOKEN=

# --- Medusa Cloud (Docs MCP token; used by .cursor/mcp.json) ---
MEDUSA_CLOUD_TOKEN=
